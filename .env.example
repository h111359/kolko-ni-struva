# .env.example: Template for all required environment variables.
# Copy this file to .env and fill in your real credentials.
# IMPORTANT: .env must NOT be committed to version control — it is excluded
# by .gitignore. The .env.example file (this file) is safe to commit.
#
# This file documents both server-side secrets (used by Python scripts) and
# client-side variables (used by the React frontend). Only variables prefixed
# with VITE_ are exposed to the client; other variables remain server-only.

# ---------------------------------------------------------------------------
# SERVER-SIDE ONLY (Python scripts & deployment)
# ---------------------------------------------------------------------------
# These variables are used by src/load_supabase.py and src/deploy_netlify.py.
# They are NOT exposed to the React frontend and must be treated as secrets.

# Supabase credentials (used by src/load_supabase.py for ETL database sync)
# Direct connection string for Supabase PostgreSQL (port 5432).
# Use port 5432 for direct connections; port 6543 is the pooler endpoint
# and may cause mid-batch disconnections on large uploads.
# Obtain from: Supabase Dashboard → Settings → Database → Connection string (URI).
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Netlify credentials (used by src/deploy_netlify.py for React app deployment)
# Personal access token for Netlify CLI authentication.
# Obtain from: app.netlify.com → Avatar → User settings → Applications
#              → Personal access tokens → New access token.
# The token is shown only once; store it here immediately after generating it.
NETLIFY_AUTH_TOKEN=your_netlify_personal_access_token_here

# Site ID (UUID) of the target Netlify site.
# Obtain from: app.netlify.com → your site → Site configuration → General
#              → Site details → Site ID.
# Format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NETLIFY_SITE_ID=your_netlify_site_id_here

# ---------------------------------------------------------------------------
# CLIENT-SIDE (React frontend via Vite)
# Prefix: VITE_
# ---------------------------------------------------------------------------
# These variables are exposed to the React frontend via the Vite build system.
# Only variables prefixed with VITE_ are made available to browser code.
# The values below are the PUBLIC Supabase credentials (anon key, not secret).
# DO NOT store secrets or service role keys here.

# Supabase project URL (public-safe)
# Obtain from: Supabase Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous public key (public-safe, not a secret)
# Obtain from: Supabase Dashboard → Settings → API → anon (public key)
# This is the public-scoped key; it does not grant admin access.
VITE_SUPABASE_ANON_KEY=your-anon-key-here
